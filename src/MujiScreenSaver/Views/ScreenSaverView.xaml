<UserControl x:Class="MujiScreenSaver.Views.ScreenSaverView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:MujiScreenSaver.Views"
             Background="{StaticResource PaperBrush}"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">
    <UserControl.Resources>
        <Style x:Key="WeekDayStyle" TargetType="Border">
            <Setter Property="Width" Value="72" />
            <Setter Property="Padding" Value="0,0,0,10" />
            <Setter Property="BorderBrush" Value="{StaticResource InkBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsToday}" Value="True">
                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource PaperBrush}">
        <Viewbox Stretch="Uniform">
            <Grid Width="1600" Height="900" Margin="132,88,132,96" Background="{StaticResource PaperBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="42" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Vertical">
                    <TextBlock Text="{Binding DateText}"
                               FontFamily="{StaticResource TextFont}"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource InkBrush}" />

                    <ItemsControl ItemsSource="{Binding WeekDays}" Margin="0,32,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource WeekDayStyle}" Margin="0,0,22,0">
                                    <StackPanel>
                                        <TextBlock Text="{Binding DayLabel}"
                                                   HorizontalAlignment="Center"
                                                   FontFamily="{StaticResource TextFont}"
                                                   FontSize="18"
                                                   Foreground="{StaticResource MutedBrush}" />
                                        <TextBlock Text="{Binding DateLabel}"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,10,0,0"
                                                   FontFamily="{StaticResource TextFont}"
                                                   FontSize="24"
                                                   Foreground="{StaticResource InkBrush}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <TextBlock Grid.Row="2"
                           Text="{Binding TimeText}"
                           Margin="-8,78,0,0"
                           FontFamily="{StaticResource DisplayFont}"
                           FontSize="188"
                           FontWeight="Light"
                           Foreground="{StaticResource InkBrush}" />

                <ItemsControl Grid.Row="4"
                              ItemsSource="{Binding Timers}"
                              Width="880"
                              HorizontalAlignment="Left">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,30"
                                  Visibility="{Binding IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="16" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{Binding Label}"
                                           FontFamily="{StaticResource TextFont}"
                                           FontSize="22"
                                           Foreground="{StaticResource InkBrush}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding RemainingText}"
                                           FontFamily="{StaticResource TextFont}"
                                           FontSize="22"
                                           Foreground="{StaticResource InkBrush}" />

                                <views:TimerProgressBar Grid.Row="1"
                                                        Grid.ColumnSpan="2"
                                                        Height="16"
                                                        Progress="{Binding Progress}"
                                                        TrackBrush="{StaticResource RuleBrush}"
                                                        FillBrush="{StaticResource InkBrush}"
                                                        BarHeight="2" />

                                <TextBlock Grid.Row="2"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding ElapsedTotalText}"
                                           FontFamily="{StaticResource TextFont}"
                                           FontSize="14"
                                           Foreground="{StaticResource MutedBrush}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Viewbox>
    </Grid>
</UserControl>
