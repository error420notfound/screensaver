<Window x:Class="MujiScreenSaver.Views.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:MujiScreenSaver.Views"
        Title="Muji Screen Saver"
        Width="620"
        Height="520"
        MinWidth="560"
        MinHeight="460"
        Background="{StaticResource PaperBrush}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource TextFont}" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="{StaticResource TextFont}" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Background" Value="{StaticResource PaperBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource RuleBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="0,4,0,4" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="{StaticResource TextFont}" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Background" Value="{StaticResource PaperBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource RuleBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="FontFamily" Value="{StaticResource TextFont}" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Timers"
                       FontSize="26"
                       FontWeight="SemiBold" />
            <TextBlock Text="Configure up to three quiet timers for the screensaver."
                       Margin="0,6,0,24"
                       FontSize="13"
                       Foreground="{StaticResource MutedBrush}" />
        </StackPanel>

        <ItemsControl Grid.Row="1" ItemsSource="{Binding Timers}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="{StaticResource RuleBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="0,18"
                            Margin="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="96" />
                            </Grid.ColumnDefinitions>

                            <CheckBox Content="Show timer"
                                      IsChecked="{Binding IsVisible, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding StatusText}"
                                       HorizontalAlignment="Right"
                                       Foreground="{StaticResource MutedBrush}" />

                            <TextBox Grid.Row="1"
                                     Margin="0,12,18,0"
                                     Text="{Binding Label, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            <StackPanel Grid.Row="1"
                                        Grid.Column="1"
                                        Margin="0,12,0,0">
                                <TextBlock Text="Minutes"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedBrush}" />
                                <TextBox Text="{Binding DurationMinutes, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            </StackPanel>

                            <StackPanel Grid.Row="2"
                                        Grid.ColumnSpan="2"
                                        Orientation="Horizontal"
                                        Margin="0,16,0,0">
                                <Button Content="Start" Command="{Binding StartCommand}" />
                                <Button Content="Pause" Command="{Binding PauseCommand}" />
                                <Button Content="Reset" Command="{Binding ResetCommand}" />
                            </StackPanel>

                            <views:TimerProgressBar Grid.Row="2"
                                                    Grid.ColumnSpan="2"
                                                    Height="16"
                                                    Margin="260,18,0,0"
                                                    HorizontalAlignment="Stretch"
                                                    Progress="{Binding Progress}"
                                                    TrackBrush="{StaticResource RuleBrush}"
                                                    FillBrush="{StaticResource InkBrush}"
                                                    BarHeight="2" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <TextBlock Grid.Row="2"
                   Text="{Binding StoragePath}"
                   Margin="0,18,0,0"
                   FontSize="11"
                   TextTrimming="CharacterEllipsis"
                   Foreground="{StaticResource MutedBrush}" />
    </Grid>
</Window>
