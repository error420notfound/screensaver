<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="PaperColor">#F3F0E8</Color>
    <Color x:Key="InkColor">#24231F</Color>
    <Color x:Key="MutedColor">#747067</Color>
    <Color x:Key="RuleColor">#CFC9BD</Color>

    <SolidColorBrush x:Key="PaperBrush" Color="{StaticResource PaperColor}" />
    <SolidColorBrush x:Key="InkBrush" Color="{StaticResource InkColor}" />
    <SolidColorBrush x:Key="MutedBrush" Color="{StaticResource MutedColor}" />
    <SolidColorBrush x:Key="RuleBrush" Color="{StaticResource RuleColor}" />
</ResourceDictionary>
